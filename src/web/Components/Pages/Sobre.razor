@page "/sobre"
@layout Layout.PublicLayout
@inject NavigationManager Navigation
@inject NavigationContextService NavCtx

<PageTitle>Sobre - Simple Party List</PageTitle>

<div class="login-section">
    <div class="login-card" style="text-align:center;">
        <div class="login-logo">
            <img src="/images/logoverde.png" alt="SPL">
        </div>
        <h3>Sobre</h3>
        <p style="font-size:0.9rem;color:#333;margin-bottom:10px;line-height:1.6;">
            Esta aplicação nasceu durante os preparativos para o chá de bebê do meu filho Ethan. A ideia era criar uma forma simples e prática de organizar a lista de presentes e facilitar a participação de todos.
        </p>
        <p style="font-size:0.85rem;color:#777;margin-bottom:0;line-height:1.5;">
            O Simple Party List permite que os convidados acessem um link público, escolham os itens desejados e que o organizador acompanhe as escolhas em tempo real.
        </p>
        <button class="btn btn-outline-primary btn-custom" style="margin-top:20px;"
                @onclick="Voltar">Voltar</button>
    </div>
</div>

@code {
    private void Voltar()
    {
        Navigation.NavigateTo(NavCtx.Origem switch
        {
            "Admin" => "/admin/dashboard",
            "Publico" => "/",
            _ => "/"
        });
    }
}
