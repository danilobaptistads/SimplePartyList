@page "/admin/dashboard"
@rendermode InteractiveServer
@layout Layout.MainLayout
@inject AdminAuthHelper Auth
@inject NavigationManager Navigation

<PageTitle>Dashboard - Simple Party List</PageTitle>

@if (!Auth.IsAuthenticated)
{
    <div class="login-section" style="padding:20px 0;">
        <div class="login-card" style="margin:0;max-width:100%;">
            <div class="login-logo"><img src="/images/logoverde.png" alt="SPL"></div>
            <h3>Login</h3>
            @if (_erroLogin is not null)
            {
                <div class="login-error">@_erroLogin</div>
            }
            <div class="field">
                <input type="email" placeholder="Email"
                       @bind-value="@_emailLogin"
                       @bind-value:event="oninput" />
            </div>
            <div class="field">
                <input type="password" placeholder="Senha"
                       @bind-value="@_senhaLogin"
                       @bind-value:event="oninput" />
            </div>
            <button class="btn-login" @onclick="LoginAsync" disabled="@_carregandoLogin">ENTRAR</button>
        </div>
    </div>
    return;
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h3 style="color: var(--color-primary); margin: 0;">Meus Eventos</h3>
    <button class="btn btn-primary btn-dashboard-new" @onclick="IrCriarEvento">+ Novo Evento</button>
</div>

@if (_carregando)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2 text-muted">Carregando eventos...</p>
    </div>
}
else if (_erro is not null)
{
    <div class="alert alert-danger">@_erro</div>
}
else if (_eventos is null || _eventos.Count == 0)
{
    <div class="card-beige text-center">
        <p class="text-muted mb-0">Nenhum evento encontrado. Crie seu primeiro evento!</p>
    </div>
}
else
{
    <div class="event-list">
        @foreach (var ev in _eventos)
        {
            <div class="card-beige event-card" @onclick="() => IrDetalhe(ev.EventId)">
                <button class="event-card-remove"
                        @onclick:stopPropagation
                        @onclick="() => _eventoParaExcluir = ev">×</button>
                <h4 class="event-card-title">@ev.Name</h4>
                <p class="event-card-date">@ev.Date.ToString("dd 'de' MMMM 'de' yyyy")</p>
                <small class="text-muted">ListUrl: @ev.ListUrl</small>
            </div>
        }
    </div>
}

@if (_eventoParaExcluir is not null)
{
    <div class="modal-overlay">
        <div class="modal-card">
            <h3 class="text-center mb-3" style="color: var(--color-primary);">Remover evento</h3>
            <p class="text-center">Deseja remover o evento <strong>@_eventoParaExcluir.Name</strong>?</p>
            <p class="text-center text-muted small">Esta ação não pode ser desfeita.</p>
            @if (_erroExcluir is not null)
            {
                <div class="alert alert-danger text-center">@_erroExcluir</div>
            }
            <div class="modal-actions">
                <button class="btn btn-outline-secondary btn-custom" @onclick="CancelarExclusao" disabled="@_excluindo">Cancelar</button>
                <button class="btn btn-danger btn-custom" @onclick="ConfirmarExclusao" disabled="@_excluindo">
                    @if (_excluindo)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    REMOVER
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<AdminEventResponseDto>? _eventos;
    private bool _carregando = true;
    private string? _erro;

    private string _emailLogin = string.Empty;
    private string _senhaLogin = string.Empty;
    private string? _erroLogin;
    private bool _carregandoLogin;

    protected override async Task OnInitializedAsync()
    {
        if (Auth.IsAuthenticated)
            await CarregarEventos();
        else
            _carregando = false;
    }

    private async Task LoginAsync()
    {
        _carregandoLogin = true;
        _erroLogin = null;
        try
        {
            if (await Auth.LoginAsync(_emailLogin, _senhaLogin))
            {
                _emailLogin = string.Empty;
                _senhaLogin = string.Empty;
                await CarregarEventos();
            }
            else
                _erroLogin = "Email ou senha inválidos";
        }
        catch
        {
            _erroLogin = "Erro de conexão";
        }
        finally
        {
            _carregandoLogin = false;
        }
    }

    private async Task CarregarEventos()
    {
        _carregando = true;
        try
        {
            _eventos = await Auth.GetAsync<List<AdminEventResponseDto>>("/api/events");
            if (_eventos is null)
                _erro = "Erro ao carregar eventos";
        }
        catch
        {
            _erro = "Erro de conexão";
        }
        finally
        {
            _carregando = false;
        }
    }

    private void IrDetalhe(Guid eventId)
    {
        Navigation.NavigateTo($"/admin/events/{eventId}");
    }

    private void IrCriarEvento()
    {
        Navigation.NavigateTo("/admin/events/novo");
    }

    private AdminEventResponseDto? _eventoParaExcluir;
    private bool _excluindo;
    private string? _erroExcluir;

    private async Task ConfirmarExclusao()
    {
        if (_eventoParaExcluir is null) return;
        _excluindo = true;
        _erroExcluir = null;
        try
        {
            var ok = await Auth.DeleteAsync($"/api/events/{_eventoParaExcluir.EventId}");
            if (ok)
            {
                _eventos?.Remove(_eventoParaExcluir);
                _eventoParaExcluir = null;
            }
            else
                _erroExcluir = "Erro ao remover evento";
        }
        catch
        {
            _erroExcluir = "Erro de conexão";
        }
        finally
        {
            _excluindo = false;
        }
    }

    private void CancelarExclusao()
    {
        _eventoParaExcluir = null;
        _erroExcluir = null;
    }
}
