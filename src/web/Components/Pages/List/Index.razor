@page "/list/{ListUrl:guid}"
@layout Layout.PublicLayout
@rendermode InteractiveServer
@using SimplePartyList.Core.DTOs
@inject ListPageHelper Helper
@inject NavigationManager Navigation

<PageTitle>Simple Party List</PageTitle>

@if (_errorMessage is not null)
{
    <div class="card-beige">
        <div class="tape tape--coral-superior-esquerda"></div>
        <div class="tape tape--verde-superior-direita"></div>
        <div class="alert alert-danger text-center mb-0">@_errorMessage</div>
    </div>
}
else if (_lista is null)
{
    <div class="card-beige text-center">
        <div class="tape tape--coral-superior-esquerda"></div>
        <div class="tape tape--verde-superior-direita"></div>
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Carregando lista...</p>
    </div>
}
else if (_sucesso)
{
    <div class="card-beige">
        <div class="tape tape--coral-superior-esquerda-itens"></div>
        <div class="tape tape--verde-superior-direita-itens"></div>
        <div class="tape tape--verde-inferior-direita"></div>
        <h3 class="text-center mb-4" style="color: var(--color-primary);">Obrigado!</h3>
        <div class="text-center mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="var(--color-primary)" viewBox="0 0 16 16">
                <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
            </svg>
        </div>
        <p class="text-center text-muted">Sua escolha foi registrada com sucesso!</p>
        <p class="text-center"><strong>Convidado:</strong> @_nomeConvidado</p>
        <p class="text-center"><strong>Itens escolhidos:</strong></p>
        <ul class="list-unstyled text-center">
            @foreach (var nome in _nomesItensSucesso)
            {
                <li><span class="badge" style="background: var(--color-primary);">@nome</span></li>
            }
        </ul>
        <div class="text-center mt-4">
            <button class="btn-submit" @onclick="VoltarLista">VOLTAR</button>
        </div>
    </div>
}
else
{
    if (_lista.IsExpired)
    {
        <div class="card-beige">
            <div class="tape tape--coral-superior-esquerda-itens"></div>
            <div class="tape tape--verde-superior-direita-itens"></div>
            <div class="tape tape--verde-inferior-direita"></div>
            <div class="alert alert-warning text-center mb-0">Esta lista expirou. Visualização apenas.</div>
        </div>
    }

    <div class="event-header">
        <h2 class="event-title">@_lista.EventName</h2>
        <p class="event-date">@_lista.EventDate.ToString("dd 'de' MMMM 'de' yyyy")</p>
    </div>

    <div class="card-beige">
        <div class="tape tape--coral-superior-esquerda"></div>
        <div class="tape tape--verde-superior-direita"></div>
        <h3 class="card-title-step">Olá! Antes de escolher um presente...</h3>
        <input class="form-control form-control-lg input-custom"
               value="@_nomeConvidado"
               @oninput="OnNomeChanged"
               placeholder="Digite seu nome completo"
               disabled="@(_lista.IsExpired)" />
    </div>

    <div class="card-beige">
        <div class="tape tape--coral-superior-esquerda-itens"></div>
        <div class="tape tape--verde-superior-direita-itens"></div>
        <div class="tape tape--verde-inferior-direita"></div>
        <h3 class="card-title-step">ITENS DISPONÍVEIS PARA ESCOLHA</h3>

        <div class="items-list">
            @foreach (var item in _lista.Items)
            {
                var idx = item.ItemId;
                var selecionado = _itensSelecionadosIds.Contains(idx);
                var disponivel = item.MaxQuantity is null || item.ChosenCount < item.MaxQuantity;
                var restantes = item.MaxQuantity.HasValue ? item.MaxQuantity.Value - item.ChosenCount : 0;
                var pctRestante = item.MaxQuantity.HasValue && item.MaxQuantity > 0
                    ? (int)((float)restantes / item.MaxQuantity.Value * 100)
                    : 0;

                <div class="item-card @(selecionado ? "selected" : "") @(!disponivel || _lista.IsExpired ? "disabled" : "")"
                     @onclick="() => AlternarItem(idx, disponivel)">
                    <div class="item-checkbox">
                        <input type="checkbox"
                               checked="@selecionado"
                               disabled="@(!disponivel || _lista.IsExpired)"
                               readonly
                               style="pointer-events: none;" />
                    </div>
                    <div class="item-info">
                        <div class="item-name">@item.Name</div>
                        @if (item.MaxQuantity.HasValue)
                        {
                            <div class="item-quota">
                                <span>@restantes/@item.MaxQuantity cotas restantes</span>
                                <div class="progress-bar-wrapper">
                                    <div class="progress-bar-fill" style="width: @pctRestante%;"></div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="item-quota">
                                <span>@item.ChosenCount escolhido(s)</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        @if (!_lista.IsExpired)
        {
            <button class="btn-submit"
                    disabled="@(_itensSelecionadosIds.Count == 0 || string.IsNullOrWhiteSpace(_nomeConvidado))"
                    @onclick="AbrirPopup">
                @if (_carregando)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                }
                SUBMETER ESCOLHAS
            </button>
            <div class="validation-area">
                @if (_itemTocado && string.IsNullOrWhiteSpace(_nomeConvidado))
                {
                    <p class="validation-hint">Informe seu nome</p>
                }
                @if (_nomeTocado && _itensSelecionadosIds.Count == 0)
                {
                    <p class="validation-hint">Selecione ao menos um item</p>
                }
            </div>
        }
    </div>
}

@if (_mostrarPopup)
{
    <PopupConfirmacao
        GuestName="@_nomeConvidado"
        SelectedItems="@_nomesItensSelecionados"
        OnConfirm="ConfirmarEscolha"
        OnEdit="FecharPopup" />
}

@code {
    [Parameter] public Guid ListUrl { get; set; }

    private PublicListResponseDto? _lista;
    private readonly HashSet<Guid> _itensSelecionadosIds = [];
    private string _nomeConvidado = string.Empty;
    private bool _nomeTocado;
    private bool _itemTocado;
    private bool _mostrarPopup;
    private bool _sucesso;
    private bool _carregando;
    private string? _errorMessage;
    private List<string> _nomesItensSucesso = [];
    private List<string> _nomesItensSelecionados => _lista?.Items
        .Where(i => _itensSelecionadosIds.Contains(i.ItemId))
        .Select(i => i.Name)
        .ToList() ?? [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _lista = await Helper.CarregarListaAsync(ListUrl.ToString());
            if (_lista is null)
                _errorMessage = "Lista não encontrada.";
        }
        catch
        {
            _errorMessage = "Erro ao carregar a lista.";
        }
    }

    private void OnNomeChanged(ChangeEventArgs e)
    {
        _nomeConvidado = e.Value?.ToString() ?? "";
        _nomeTocado = true;
    }

    private void AlternarItem(Guid itemId, bool disponivel)
    {
        if (!disponivel || _lista?.IsExpired == true) return;

        if (_itensSelecionadosIds.Contains(itemId))
            _itensSelecionadosIds.Remove(itemId);
        else
            _itensSelecionadosIds.Add(itemId);

        _itemTocado = true;
    }

    private async Task AbrirPopup()
    {
        _mostrarPopup = true;
        await Task.CompletedTask;
    }

    private async Task FecharPopup()
    {
        _mostrarPopup = false;
        await Task.CompletedTask;
    }

    private async Task ConfirmarEscolha()
    {
        _mostrarPopup = false;
        _carregando = true;
        StateHasChanged();

        try
        {
            var itens = _lista!.Items.Where(i => _itensSelecionadosIds.Contains(i.ItemId)).ToList();
            foreach (var item in itens)
            {
                await Helper.SubmeterEscolhaAsync(ListUrl.ToString(), _nomeConvidado, item.ItemId);
            }
            _nomesItensSucesso = itens.Select(i => i.Name).ToList();
            _sucesso = true;
        }
        catch (InvalidOperationException ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _carregando = false;
        }
    }

    private void VoltarLista()
    {
        Navigation.NavigateTo($"/list/{ListUrl}", forceLoad: true);
    }
}
