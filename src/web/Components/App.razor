<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["SimplePartyList.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="/images/logoverde.png" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <script src="_framework/blazor.web.js"></script>
    <script>
        Blazor.start({
            reconnectionOptions: {
                maxRetries: 30,
                retryIntervalMilliseconds: 2000
            }
        }).then(function () {
            var err = document.getElementById('blazor-error-ui');
            if (err) err.style.display = 'none';
        });

        document.addEventListener('blazor:reconnected', function () {
            var err = document.getElementById('blazor-error-ui');
            if (err) err.style.display = 'none';
        });

        document.addEventListener('blazor:disconnected', function () {
            console.warn('Circuito desconectado, tentando religar...');
        });
    </script>
</body>

</html>
