@inject NavigationManager Navigation
@inherits LayoutComponentBase

<div class="top-bar">
    <div class="logo">
        <img src="/images/logobranco.png" alt="SPL" class="logo-img">
        SIMPLE PARTY LIST
    </div>
    <a href="#"
       class="admin-link"
       @onclick="OpenAbout"
       @onclick:preventDefault="true">SOBRE</a>
</div>

<main class="page-wrapper">
    @Body
</main>

@code {
    private void OpenAbout()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri);
        Navigation.NavigateTo($"/sobre?returnUrl={Uri.EscapeDataString(path)}");
    }
}
