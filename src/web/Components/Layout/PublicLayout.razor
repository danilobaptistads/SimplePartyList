@inherits LayoutComponentBase
@inject NavigationManager Navigation

<div class="top-bar">
    <div class="logo">
        <img src="/images/logobranco.png" alt="SPL" class="logo-img">
        SIMPLE PARTY LIST
    </div>
    <a href="@GetSobreUrl()" class="admin-link">SOBRE</a>
</div>

<main class="page-wrapper">
    @Body
</main>

@code {
    private string GetSobreUrl()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri);
        return $"/sobre?returnUrl={Uri.EscapeDataString(path)}";
    }
}
