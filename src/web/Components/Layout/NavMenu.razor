@inject AdminAuthHelper Auth
@inject NavigationManager Navigation

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">
            <img src="/images/logobranco.png" alt="SPL" class="sidebar-logo">
            <span class="brand-text">SimplePartyList</span>
        </a>
    </div>
</div>

<div class="nav-scrollable">
    <nav class="nav flex-column" @onclick="HandleNavClick">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/admin/dashboard" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/admin/events/novo">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Novo Evento
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/sobre">
                <span class="bi bi-info-circle-fill-nav-menu" aria-hidden="true"></span> Sobre
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <a href="#" class="nav-link" @onclick="LogoutOrRedirect" @onclick:preventDefault="true">
                <span class="bi bi-box-arrow-right-nav-menu" aria-hidden="true"></span> Sair
            </a>
        </div>
    </nav>
</div>

@code {
    [Parameter]
    public EventCallback OnNavClick { get; set; }

    private async Task HandleNavClick()
    {
        await OnNavClick.InvokeAsync();
    }

    private async Task LogoutOrRedirect()
    {
        if (Auth.IsAuthenticated)
        {
            Auth.Logout();
            Navigation.NavigateTo("/login", forceLoad: true);
        }
        else
        {
            Navigation.NavigateTo("/login");
        }
        await Task.CompletedTask;
    }
}
